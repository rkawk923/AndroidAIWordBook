<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="24dp"
    android:paddingTop="16dp"
    android:paddingBottom="16dp">

    <!-- Vocabulary Name Input -->
    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="단어장 이름"
        app:boxStrokeColor="#0058bc"
        app:hintTextColor="#0058bc"
        android:layout_marginBottom="16dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_dialog_vocab_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:maxLines="1"
            android:textColor="#1a1b1f" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Vocabulary Description Input -->
    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="단어장 설명 (여행 회화, 시험 대비 등)"
        app:boxStrokeColor="#0058bc"
        app:hintTextColor="#0058bc">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_dialog_vocab_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:maxLines="3"
            android:textColor="#1a1b1f" />

    </com.google.android.material.textfield.TextInputLayout>

</LinearLayout>
