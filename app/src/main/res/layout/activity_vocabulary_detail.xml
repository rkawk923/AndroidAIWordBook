<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#faf9fe"
    tools:context=".VocabularyDetailActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Toolbar Section -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="#ffffff"
            android:paddingHorizontal="16dp"
            android:elevation="2dp">

            <ImageView
                android:id="@+id/btn_detail_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:padding="8dp"
                android:src="@android:drawable/ic_menu_revert"
                android:tint="#0058bc"
                android:contentDescription="뒤로가기" />

            <TextView
                android:id="@+id/tv_detail_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_toEndOf="@id/btn_detail_back"
                android:layout_marginStart="12dp"
                android:text="영단어 카드 학습"
                android:textColor="#1a1b1f"
                android:textSize="18sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/btn_detail_bookmark"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:padding="8dp"
                android:src="@android:drawable/btn_star_big_off"
                android:contentDescription="북마크" />

        </RelativeLayout>

        <!-- Divider line under toolbar -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#e3e2e7" />

        <!-- Flashcard Study Mode Container -->
        <LinearLayout
            android:id="@+id/view_study_mode"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="20dp"
            android:visibility="visible">

            <!-- Progress Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="bottom"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="학습 진행도"
                    android:textColor="#414755"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/tv_study_progress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 / 0"
                    android:textColor="#0058bc"
                    android:textSize="14sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- Custom Progress Bar -->
            <ProgressBar
                android:id="@+id/pb_study"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:layout_marginBottom="32dp"
                android:progressDrawable="@drawable/bg_progress_horizontal"
                android:max="100"
                android:progress="0" />

            <!-- Word Card Container -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_word_display"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="1dp"
                app:strokeColor="#e3e2e7"
                app:cardBackgroundColor="#ffffff"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_study_word"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Word"
                        android:textColor="#1a1b1f"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Meaning Hide/Show Interactive Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_meaning_display"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="2dp"
                app:strokeColor="#c1c6d7"
                app:cardBackgroundColor="#eeedf3"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground">

                <LinearLayout
                    android:id="@+id/layout_reveal_container"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <ImageView
                        android:id="@+id/iv_reveal_icon"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@android:drawable/ic_menu_view"
                        android:tint="#717786"
                        android:contentDescription="뜻 보기" />

                    <TextView
                        android:id="@+id/tv_reveal_hint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="탭하여 뜻 보기"
                        android:textColor="#414755"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_study_meaning"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="뜻"
                        android:textColor="#0058bc"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:visibility="gone" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Spacer -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Slide Navigation controls at bottom of cards -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_study_prev"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="이전"
                    android:textColor="#0058bc"
                    android:textSize="15sp"
                    app:strokeColor="#0058bc"
                    app:strokeWidth="1.5dp"
                    app:cornerRadius="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_study_next"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="다음"
                    android:textColor="#ffffff"
                    android:textSize="15sp"
                    app:backgroundTint="#0058bc"
                    app:cornerRadius="12dp" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
