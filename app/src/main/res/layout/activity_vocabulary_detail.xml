<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    android:fitsSystemWindows="true"
    tools:context=".VocabularyDetailActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Toolbar Section -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/app_bar_height"
            android:background="@color/app_surface"
            android:paddingHorizontal="@dimen/space_16"
            android:elevation="@dimen/card_elevation">

            <ImageView
                android:id="@+id/btn_detail_back"
                android:layout_width="@dimen/touch_target"
                android:layout_height="@dimen/touch_target"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:padding="@dimen/space_12"
                android:src="@android:drawable/ic_menu_revert"
                android:tint="@color/app_primary"
                android:contentDescription="뒤로가기" />

            <TextView
                android:id="@+id/tv_detail_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_toEndOf="@id/btn_detail_back"
                android:layout_toStartOf="@id/btn_detail_bookmark"
                android:layout_marginStart="@dimen/space_8"
                android:layout_marginEnd="@dimen/space_8"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="영단어 카드 학습"
                android:textAppearance="@style/TextAppearance.AIWordBook.Title" />

            <ImageView
                android:id="@+id/btn_detail_bookmark"
                android:layout_width="@dimen/touch_target"
                android:layout_height="@dimen/touch_target"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:padding="@dimen/space_12"
                android:src="@android:drawable/btn_star_big_off"
                android:contentDescription="북마크" />

        </RelativeLayout>

        <!-- Divider line under toolbar -->
        <View
            android:layout_width="match_parent"
            android:layout_height="@dimen/stroke_width"
            android:background="@color/app_divider" />

        <!-- Flashcard Study Mode Container -->
        <ScrollView
            android:id="@+id/view_study_mode"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/screen_padding"
                android:paddingBottom="@dimen/space_24">

            <!-- Progress Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="bottom"
                android:layout_marginBottom="@dimen/space_8">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="학습 진행도"
                    android:textColor="@color/app_text_secondary"
                    android:textSize="@dimen/text_body"
                    android:textStyle="bold" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="@dimen/stroke_width"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/tv_study_progress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 / 0"
                    android:textColor="@color/app_primary"
                    android:textSize="@dimen/text_body"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- Custom Progress Bar -->
            <ProgressBar
                android:id="@+id/pb_study"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="@dimen/space_8"
                android:layout_marginBottom="@dimen/space_24"
                android:progressDrawable="@drawable/bg_progress_horizontal"
                android:max="100"
                android:progress="0" />

            <!-- Word Card Container -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_word_display"
                style="@style/Widget.AIWordBook.Card"
                android:layout_width="match_parent"
                android:layout_height="@dimen/study_card_height"
                android:layout_marginBottom="@dimen/space_16">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_study_word"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:maxLines="4"
                        android:paddingHorizontal="@dimen/space_16"
                        android:text="Word"
                        android:textColor="@color/app_text_primary"
                        android:textSize="@dimen/text_display"
                        android:textStyle="bold" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Meaning Hide/Show Interactive Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_meaning_display"
                style="@style/Widget.AIWordBook.Card"
                android:layout_width="match_parent"
                android:layout_height="@dimen/study_card_height"
                app:cardBackgroundColor="@color/app_surface_subtle"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground">

                <LinearLayout
                    android:id="@+id/layout_reveal_container"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding">

                    <ImageView
                        android:id="@+id/iv_reveal_icon"
                        android:layout_width="@dimen/space_32"
                        android:layout_height="@dimen/space_32"
                        android:src="@android:drawable/ic_menu_view"
                        android:tint="@color/app_text_tertiary"
                        android:contentDescription="뜻 보기" />

                    <TextView
                        android:id="@+id/tv_reveal_hint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_8"
                        android:text="탭하여 뜻 보기"
                        android:textColor="@color/app_text_secondary"
                        android:textSize="@dimen/text_body_large"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_study_meaning"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:maxLines="4"
                        android:text="뜻"
                        android:textColor="@color/app_primary"
                        android:textSize="@dimen/text_headline"
                        android:textStyle="bold"
                        android:visibility="gone" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Spacer -->
            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/space_24" />

            <!-- Slide Navigation controls at bottom of cards -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height_large"
                android:orientation="horizontal"
                android:layout_marginBottom="@dimen/space_8">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_study_prev"
                    style="@style/Widget.AIWordBook.Button.Secondary"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="@dimen/space_8"
                    android:text="이전" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_study_next"
                    style="@style/Widget.AIWordBook.Button.Primary"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/space_8"
                    android:text="다음" />

            </LinearLayout>

            </LinearLayout>

        </ScrollView>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
