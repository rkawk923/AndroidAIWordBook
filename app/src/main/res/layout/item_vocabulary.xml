<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_vocabulary"
    style="@style/Widget.AIWordBook.Card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/screen_padding"
    android:layout_marginVertical="@dimen/space_6"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/card_padding">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_toStartOf="@id/iv_favorite"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_vocab_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:text="비즈니스 영어 실전"
                    android:textAppearance="@style/TextAppearance.AIWordBook.Title" />

                <TextView
                    android:id="@+id/tv_vocab_desc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_6"
                    android:ellipsize="end"
                    android:maxLines="3"
                    android:text="실제 비즈니스 미팅과 이메일 작성 시 가장 자주 사용되는 실무 영어 표현"
                    android:textAppearance="@style/TextAppearance.AIWordBook.Body.Secondary" />

            </LinearLayout>

            <ImageView
                android:id="@+id/iv_favorite"
                android:layout_width="@dimen/space_24"
                android:layout_height="@dimen/space_24"
                android:layout_alignParentEnd="true"
                android:layout_alignParentTop="true"
                android:src="@android:drawable/btn_star_big_off"
                android:contentDescription="즐겨찾기"
                android:visibility="gone" />

        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_16"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_edit"
                style="@style/Widget.AIWordBook.Button.Secondary"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_height"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/space_6"
                android:text="수정" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_delete"
                style="@style/Widget.AIWordBook.Button.Danger"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_height"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/space_6"
                android:text="삭제" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
