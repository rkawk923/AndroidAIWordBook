<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_vocabulary"
    style="@style/Widget.AIWordBook.Card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/screen_padding"
    android:layout_marginTop="@dimen/space_8"
    android:layout_marginBottom="@dimen/space_4"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?android:attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/card_padding"
        android:paddingTop="@dimen/space_16"
        android:paddingBottom="@dimen/space_12">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_toStartOf="@id/iv_favorite"
                android:layout_marginEnd="@dimen/space_8"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_vocab_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:text="비즈니스 영어 실전"
                    android:textAppearance="@style/TextAppearance.AIWordBook.Title"
                    android:textSize="@dimen/text_body_large" />

                <TextView
                    android:id="@+id/tv_vocab_desc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_4"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:text="실제 비즈니스 미팅과 이메일 작성 시 가장 자주 사용되는 실무 영어 표현"
                    android:textAppearance="@style/TextAppearance.AIWordBook.Body.Secondary" />

            </LinearLayout>

            <ImageButton
                android:id="@+id/iv_favorite"
                android:layout_width="@dimen/touch_target"
                android:layout_height="@dimen/touch_target"
                android:layout_alignParentEnd="true"
                android:layout_alignParentTop="true"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/add_to_favorites"
                android:padding="@dimen/space_12"
                android:src="@drawable/ic_heart_outline" />

        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_12"
            android:gravity="end"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_edit"
                style="@style/Widget.AIWordBook.Button.CardAction"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/space_8"
                android:minHeight="@dimen/card_action_height"
                android:maxLines="2"
                android:text="수정" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_delete"
                style="@style/Widget.AIWordBook.Button.CardAction.Danger"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minHeight="@dimen/card_action_height"
                android:maxLines="2"
                android:text="삭제" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
