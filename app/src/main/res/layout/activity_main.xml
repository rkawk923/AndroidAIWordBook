<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_background"
    android:fitsSystemWindows="true"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Top AppBar -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/app_bar_height"
            android:background="@color/app_surface"
            android:elevation="@dimen/card_elevation"
            android:paddingHorizontal="@dimen/space_16">

            <ImageView
                android:id="@+id/btn_menu"
                android:layout_width="@dimen/touch_target"
                android:layout_height="@dimen/touch_target"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:padding="@dimen/space_12"
                android:src="@android:drawable/ic_menu_sort_by_size"
                android:tint="@color/app_primary"
                android:contentDescription="메뉴" />

            <TextView
                android:id="@+id/tv_main_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_toEndOf="@id/btn_menu"
                android:layout_toStartOf="@id/btn_profile"
                android:layout_marginStart="@dimen/space_8"
                android:layout_marginEnd="@dimen/space_8"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="AI 스마트 단어장"
                android:textColor="@color/app_primary"
                android:textSize="@dimen/text_title"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/btn_profile"
                android:layout_width="@dimen/touch_target"
                android:layout_height="@dimen/touch_target"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:padding="@dimen/space_12"
                android:src="@android:drawable/sym_def_app_icon"
                android:contentDescription="프로필" />

        </RelativeLayout>

        <!-- Container for Multi-Tab Contents -->
        <FrameLayout
            android:id="@+id/main_content_container"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <!-- TAB 1: 단어장 목록 페이지 (최초 기본 활성 상태) -->
            <LinearLayout
                android:id="@+id/tab_container_vocab"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="visible">

                <androidx.core.widget.NestedScrollView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipToPadding="false"
                    android:fillViewport="true"
                    android:overScrollMode="never">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingBottom="@dimen/vocabulary_list_bottom_padding"
                        android:paddingTop="@dimen/space_16">

                        <!-- Search Input Container -->
                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="@dimen/screen_padding">

                            <EditText
                                android:id="@+id/et_search"
                                android:layout_width="match_parent"
                                android:layout_height="@dimen/input_height"
                                android:background="@drawable/bg_search_input"
                                android:hint="단어장 검색"
                                android:textColorHint="@color/app_text_tertiary"
                                android:textSize="@dimen/text_body"
                                android:inputType="text"
                                android:maxLines="1"
                                android:paddingStart="@dimen/space_48"
                                android:paddingEnd="@dimen/space_16"
                                android:selectAllOnFocus="false"
                                android:textColor="@color/app_text_primary" />

                            <ImageView
                                android:layout_width="@dimen/space_20"
                                android:layout_height="@dimen/space_20"
                                android:layout_gravity="start|center_vertical"
                                android:layout_marginStart="@dimen/space_16"
                                android:src="@android:drawable/ic_menu_search"
                                android:tint="@color/app_text_tertiary"
                                android:contentDescription="검색 아이콘" />

                        </FrameLayout>

                        <!-- Section Title Row -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="@dimen/screen_padding"
                            android:layout_marginTop="@dimen/space_20"
                            android:layout_marginBottom="@dimen/space_8">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentStart="true"
                                android:layout_centerVertical="true"
                                android:text="내 단어장"
                                android:textAppearance="@style/TextAppearance.AIWordBook.Title"
                                android:textSize="@dimen/text_body_large" />

                            <TextView
                                android:id="@+id/btn_view_all"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:text="전체보기"
                                android:textColor="@color/app_primary"
                                android:textSize="@dimen/text_caption"
                                android:background="?android:attr/selectableItemBackground"
                                android:fontFamily="sans-serif-medium"
                                android:paddingHorizontal="@dimen/space_8"
                                android:paddingVertical="@dimen/space_4" />

                        </RelativeLayout>

                        <!-- RecyclerView for Vocabulary list -->
                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rv_vocabularies"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:clipToPadding="false"
                            android:nestedScrollingEnabled="false"
                            tools:listitem="@layout/item_vocabulary" />

                        <!-- Empty State View -->
                        <LinearLayout
                            android:id="@+id/layout_empty_state"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/empty_state_height"
                            android:layout_marginHorizontal="@dimen/screen_padding"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="@dimen/space_20"
                            android:visibility="gone">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="아직 단어장이 없습니다"
                                android:textAppearance="@style/TextAppearance.AIWordBook.Title"
                                android:textSize="@dimen/text_body_large" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/space_8"
                                android:text="아래 추가 탭에서 첫 단어장을 만들어보세요."
                                android:gravity="center"
                                android:textAppearance="@style/TextAppearance.AIWordBook.Body.Secondary" />

                        </LinearLayout>

                    </LinearLayout>

                </androidx.core.widget.NestedScrollView>

            </LinearLayout>

            <!-- TAB 2: 학습 레포트 페이지 (최근 방문한 단어장 통계 및 진행도 표시) -->
            <ScrollView
                android:id="@+id/tab_container_learn"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/screen_padding"
                    android:paddingBottom="@dimen/space_32">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="오늘의 학습 레포트"
                    android:textAppearance="@style/TextAppearance.AIWordBook.Headline"
                    android:layout_marginBottom="@dimen/space_16" />

                <!-- Empty State for Learn Report -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_learn_empty"
                    style="@style/Widget.AIWordBook.Card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="visible">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/report_empty_height"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="@dimen/space_24">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="학습 기록"
                            android:textColor="@color/app_primary"
                            android:textSize="@dimen/text_body"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_16"
                            android:text="학습 진행 기록이 존재하지 않습니다."
                            android:gravity="center"
                            android:textAppearance="@style/TextAppearance.AIWordBook.Title" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_8"
                            android:text="단어장을 열어 카드 학습을 진행하면\n여기에 학습 진행률이 표시됩니다."
                            android:gravity="center"
                            android:textAppearance="@style/TextAppearance.AIWordBook.Body.Secondary" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Active Stats Layout -->
                <LinearLayout
                    android:id="@+id/layout_learn_active"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <!-- Visual Progress Card -->
                    <com.google.android.material.card.MaterialCardView
                        style="@style/Widget.AIWordBook.Card.Highlight"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/space_16">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="@dimen/card_padding">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="가장 최근 학습 중인 단어장"
                                android:textColor="@color/app_primary"
                                android:textSize="@dimen/text_caption"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tv_learn_vocab_name"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/space_4"
                                android:ellipsize="end"
                                android:maxLines="2"
                                android:text="비즈니스 영어 실전"
                                android:textAppearance="@style/TextAppearance.AIWordBook.Headline" />

                            <!-- Progress Stats Circle Simulation -->
                            <RelativeLayout
                                android:layout_width="match_parent"
                                android:layout_height="@dimen/report_progress_area_height"
                                android:layout_marginTop="@dimen/space_16">

                                <ProgressBar
                                    android:id="@+id/pb_learn_circle"
                                    style="?android:attr/progressBarStyleLarge"
                                    android:layout_width="@dimen/report_progress_size"
                                    android:layout_height="@dimen/report_progress_size"
                                    android:layout_centerInParent="true"
                                    android:indeterminate="false"
                                    android:max="100"
                                    android:progress="75" />

                                <TextView
                                    android:id="@+id/tv_learn_percent"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_centerInParent="true"
                                    android:text="75%"
                                    android:textColor="@color/app_primary"
                                    android:textSize="@dimen/text_title"
                                    android:textStyle="bold" />

                            </RelativeLayout>

                            <TextView
                                android:id="@+id/tv_learn_progress_ratio"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_horizontal"
                                android:layout_marginTop="@dimen/space_12"
                                android:text="학습완료: 30 / 전체: 40 단어"
                                android:textColor="@color/app_text_secondary"
                                android:textSize="@dimen/text_body"
                                android:textStyle="bold" />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <!-- Interactive Resume Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_resume_study"
                        style="@style/Widget.AIWordBook.Button.Primary"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/button_height_large"
                        android:text="이어서 학습하기" />

                </LinearLayout>

                </LinearLayout>

            </ScrollView>

            <!-- TAB 3: 단어 입력 페이지 (네번째 사진 구현부 - 새 단어장 및 영어단어,한글뜻 입력) -->
            <ScrollView
                android:id="@+id/tab_container_add"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:fillViewport="true"
                android:overScrollMode="never"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/screen_padding"
                    android:paddingBottom="@dimen/space_32">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/space_16">

                        <TextView
                            android:id="@+id/tv_add_page_title"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_alignParentStart="true"
                            android:layout_centerVertical="true"
                            android:layout_toStartOf="@id/btn_add_help"
                            android:layout_marginEnd="@dimen/space_8"
                            android:ellipsize="end"
                            android:maxLines="2"
                            android:text="새 단어장 추가"
                            android:textAppearance="@style/TextAppearance.AIWordBook.Title" />

                        <ImageView
                            android:id="@+id/btn_add_help"
                            android:layout_width="@dimen/touch_target"
                            android:layout_height="@dimen/touch_target"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:background="?android:attr/selectableItemBackgroundBorderless"
                            android:src="@android:drawable/ic_menu_help"
                            android:tint="@color/app_text_tertiary"
                            android:padding="@dimen/space_12"
                            android:contentDescription="도움말" />

                    </RelativeLayout>

                    <!-- Vocabulary information -->
                    <com.google.android.material.card.MaterialCardView
                        style="@style/Widget.AIWordBook.Card"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/space_16">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="@dimen/card_padding">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="@dimen/space_12"
                                android:text="단어장 정보"
                                android:textAppearance="@style/TextAppearance.AIWordBook.Title"
                                android:textSize="@dimen/text_body_large" />

                            <com.google.android.material.textfield.TextInputLayout
                                style="@style/Widget.AIWordBook.TextInputLayout"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="@dimen/space_12"
                                android:hint="단어장 이름">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/et_vocab_name"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="text"
                                    android:maxLines="1"
                                    android:textColor="@color/app_text_primary"
                                    android:textSize="@dimen/text_body_large" />

                            </com.google.android.material.textfield.TextInputLayout>

                            <com.google.android.material.textfield.TextInputLayout
                                style="@style/Widget.AIWordBook.TextInputLayout"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="설명 또는 학습 목적">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/et_vocab_desc"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="top|start"
                                    android:inputType="textCapSentences|textMultiLine"
                                    android:maxLines="3"
                                    android:minLines="2"
                                    android:textColor="@color/app_text_primary"
                                    android:textSize="@dimen/text_body" />

                            </com.google.android.material.textfield.TextInputLayout>

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <!-- AI tools -->
                    <com.google.android.material.card.MaterialCardView
                        style="@style/Widget.AIWordBook.Card"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/space_16">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="@dimen/card_padding">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="AI 학습 도구"
                                android:textAppearance="@style/TextAppearance.AIWordBook.Title"
                                android:textSize="@dimen/text_body_large" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/space_4"
                                android:layout_marginBottom="@dimen/space_16"
                                android:text="PDF에서 단어를 가져오거나 입력한 단어의 빈 뜻을 채울 수 있어요."
                                android:textAppearance="@style/TextAppearance.AIWordBook.Body.Secondary" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_pdf_extract"
                                style="@style/Widget.AIWordBook.Button.Secondary"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:minHeight="@dimen/button_height"
                                android:text="PDF에서 단어 가져오기"
                                android:textColor="@color/app_primary"
                                android:maxLines="1"
                                android:layout_marginBottom="@dimen/space_8" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_ai_complete"
                                style="@style/Widget.AIWordBook.Button.Secondary"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:minHeight="@dimen/button_height"
                                android:text="빈 뜻 AI로 채우기"
                                android:textColor="@color/app_primary"
                                android:maxLines="1" />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <!-- Vocabulary entries -->
                    <com.google.android.material.card.MaterialCardView
                        style="@style/Widget.AIWordBook.Card"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/space_24">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="@dimen/card_padding">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="단어 목록"
                                android:textAppearance="@style/TextAppearance.AIWordBook.Title"
                                android:textSize="@dimen/text_body_large" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/space_4"
                                android:layout_marginBottom="@dimen/space_12"
                                android:text="영단어와 뜻을 한 쌍씩 입력해 주세요."
                                android:textAppearance="@style/TextAppearance.AIWordBook.Body.Secondary" />

                            <LinearLayout
                                android:id="@+id/container_word_rows"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:layout_marginBottom="@dimen/space_12" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_add_row"
                                style="@style/Widget.AIWordBook.Button.Secondary"
                                android:layout_width="match_parent"
                                android:layout_height="@dimen/button_height"
                                android:text="단어 추가" />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_save_vocabulary"
                        style="@style/Widget.AIWordBook.Button.Primary"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/button_height_large"
                        android:text="단어장 저장" />

                </LinearLayout>

            </ScrollView>

        </FrameLayout>

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottom_navigation"
            android:layout_width="match_parent"
            android:layout_height="@dimen/bottom_navigation_height"
            android:background="@color/app_surface"
            app:elevation="@dimen/space_8"
            app:itemIconTint="@color/nav_item_color"
            app:itemTextColor="@color/nav_item_color"
            app:labelVisibilityMode="labeled"
            app:menu="@menu/bottom_nav_menu" />

    </LinearLayout>

    <!-- Floating Action Button (FAB) -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_add_vocabulary"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="@dimen/space_20"
        android:layout_marginBottom="@dimen/fab_bottom_offset"
        android:src="@android:drawable/ic_input_add"
        android:contentDescription="단어장 추가"
        app:backgroundTint="@color/app_primary"
        app:tint="@color/app_surface"
        app:fabSize="normal" />

</FrameLayout>
