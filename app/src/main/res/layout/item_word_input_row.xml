<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingVertical="@dimen/space_6">

    <!-- Word input field -->
    <EditText
        android:id="@+id/et_row_word"
        android:layout_width="0dp"
        android:layout_height="@dimen/input_height"
        android:layout_weight="1"
        android:background="@drawable/bg_input"
        android:gravity="center_vertical"
        android:hint="영단어"
        android:textColor="@color/app_text_primary"
        android:textColorHint="@color/app_text_tertiary"
        android:textSize="@dimen/text_body"
        android:inputType="text"
        android:maxLines="1"
        android:layout_marginEnd="@dimen/space_6" />

    <!-- Meaning input field -->
    <EditText
        android:id="@+id/et_row_meaning"
        android:layout_width="0dp"
        android:layout_height="@dimen/input_height"
        android:layout_weight="1"
        android:background="@drawable/bg_input"
        android:gravity="center_vertical"
        android:hint="뜻"
        android:textColor="@color/app_text_primary"
        android:textColorHint="@color/app_text_tertiary"
        android:textSize="@dimen/text_body"
        android:inputType="text"
        android:maxLines="1" />

    <!-- Delete button -->
    <ImageView
        android:id="@+id/btn_row_delete"
        android:layout_width="@dimen/touch_target"
        android:layout_height="@dimen/touch_target"
        android:layout_marginStart="@dimen/space_4"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/ic_menu_delete"
        android:tint="@color/app_danger"
        android:scaleType="centerInside"
        android:contentDescription="삭제" />

</LinearLayout>
